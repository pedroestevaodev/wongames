# Dependencies
node_modules/

# npm
npm-debug.log*
.npm/
.npmrc.local

# The monorepo uses a single lockfile at the repository root
client/package-lock.json
api/package-lock.json

# Environment variables
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Logs
logs/
*.log
*.log.*
*.pid
*.pid.lock

# Test coverage and reports
coverage/
client/coverage/
api/coverage/
test-results/
junit.xml

# Next.js
client/.next/
client/out/
client/build/
client/next-env.d.ts

# Storybook
client/storybook-static/

# Vercel
client/.vercel/

# Strapi
api/.cache/
api/.tmp/
api/.strapi/
api/build/
api/dist/
api/exports/
api/*.tgz

# Strapi local uploads
api/public/uploads/*
!api/public/uploads/.gitkeep

# TypeScript
*.tsbuildinfo

# ESLint and tooling caches
.eslintcache
.stylelintcache
.cache/

# Husky generated files
.husky/_/
client/.husky/_/
api/.husky/_/

