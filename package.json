{
    "name": "wongames",
    "version": "1.0.0",
    "private": true,
    "engines": {
      "node": ">=20 <21",
      "npm": ">=10"
    },
    "workspaces": [
      "client",
      "api"
    ],
    "scripts": {
      "dev": "concurrently \"npm run dev --workspace=@wongames/client\" \"npm run dev --workspace=@wongames/api\"",
      "dev:client": "npm run dev --workspace=@wongames/client",
      "dev:api": "npm run dev --workspace=@wongames/api",
  
      "build": "npm run build:client && npm run build:api",
      "build:client": "npm run build --workspace=@wongames/client",
      "build:api": "npm run build --workspace=@wongames/api",
  
      "lint": "npm run lint --workspaces --if-present",
      "lint:client": "npm run lint --workspace=@wongames/client",
      "lint:api": "npm run lint --workspace=@wongames/api --if-present",
  
      "typecheck": "npm run typecheck --workspaces --if-present",
      "typecheck:client": "npm run typecheck --workspace=@wongames/client",
      "typecheck:api": "npm run typecheck --workspace=@wongames/api --if-present",
  
      "test": "npm run test --workspaces --if-present",
      "test:client": "npm run test --workspace=@wongames/client",
      "test:ci": "npm run test:ci --workspaces --if-present",
  
      "codegen": "npm run codegen --workspace=@wongames/client",
      "storybook": "npm run storybook --workspace=@wongames/client"
    },
    "devDependencies": {
      "concurrently": "^9.0.0"
    }
  }